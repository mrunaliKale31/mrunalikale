# Copy this file to .env.local for local development.
# In Vercel, add the same values in Project Settings → Environment Variables.

# Create a Resend account and paste your API key here.
# You can find it in your Resend dashboard under API Keys.
RESEND_API_KEY=

# The email address that should receive collaboration inquiries.
CONTACT_EMAIL=

# Optional: a verified sender address from your Resend account.
RESEND_FROM_EMAIL=
